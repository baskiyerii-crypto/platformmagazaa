{
  "name": "@magaza/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:clean": "node scripts/clean-start.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "lint": "tsc --noEmit",
    "build:android": "eas build -p android --profile preview-apk",
    "build:ios": "eas build -p ios --profile preview-ios",
    "publish:android": "node scripts/publish-release.js android",
    "publish:ios": "node scripts/publish-release.js ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@magaza/api-client": "workspace:*",
    "@magaza/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "expo": "^54.0.0",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.7",
    "expo-constants": "~18.0.8",
    "expo-file-system": "^57.0.0",
    "expo-image": "^57.0.0",
    "expo-image-picker": "~17.0.8",
    "expo-linking": "~8.0.8",
    "expo-notifications": "~0.32.11",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.7",
    "expo-sharing": "^57.0.3",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "^19.1.0",
    "typescript": "^5.7.2"
  }
}
